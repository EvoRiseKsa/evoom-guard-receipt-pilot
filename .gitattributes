# Receipt controls compare exact Git-object bytes. Keep reviewed text stable on
# every client, including Windows checkouts.
*.md text eol=lf
*.py text eol=lf
*.json text eol=lf
*.sha256 text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.github/workflows/** text eol=lf
evidence/negative-receipt-matrix/** -text -eol
